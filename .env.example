# Public app URL used for Stripe redirects and auth callbacks
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Supabase client config (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional fallback used by the app in some routes
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-publishable-default-key

# Supabase admin/service key (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe server-side keys
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe price IDs
# If STRIPE_PRICE_ID_MONTHLY is not set, the app falls back to STRIPE_PRICE_ID
STRIPE_PRICE_ID_MONTHLY=price_monthly_id
STRIPE_PRICE_ID=price_default_monthly_id
STRIPE_PRICE_ID_YEARLY=price_yearly_id

# Optional: used by scripts/create-admin.mjs
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=strong-password
